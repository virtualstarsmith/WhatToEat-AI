page {
  min-height: 100vh;
  background: #FFF8F3;
  color: #2B2118;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 28rpx;
}

view,
text,
button {
  box-sizing: border-box;
}

button {
  margin: 0;
  border-radius: 12rpx;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 0;
}

.section-title {
  color: #8A7968;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0;
}

/* === 位置栏（index 与 mystery 共享） === */
.loc-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 26rpx;
  background: #FFFFFF;
  border-radius: 18rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 14rpx rgba(255, 107, 53, 0.08);
}
.loc-text {
  display: flex;
  align-items: center;
  flex: 1;
  font-size: 26rpx;
  color: #2B2118;
  overflow: hidden;
  margin-right: 16rpx;
}
.loc-text.loc-warn {
  color: #8A7968;
}
.loc-icon {
  margin-right: 10rpx;
}
.loc-coord {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.loc-action {
  font-size: 26rpx;
  color: #FF6B35;
  padding: 6rpx 18rpx;
  font-weight: 600;
  background: rgba(255, 107, 53, 0.08);
  border-radius: 24rpx;
  flex-shrink: 0;
}

/* === 卡片（AI 推荐 / 盲盒结果 共享） === */
.card {
  background: #FFFFFF;
  border-radius: 22rpx;
  padding: 30rpx 28rpx 26rpx;
  box-shadow: 0 4rpx 18rpx rgba(0, 0, 0, 0.05);
}
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}
.card-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #2B2118;
  flex: 1;
  min-width: 0;
  line-height: 1.3;
  /* 长名称处理：最多 2 行后省略号，保证卡片高度稳定 */
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  word-break: break-word;
  overflow-wrap: break-word;
}
.card-type {
  font-size: 22rpx;
  color: #8A7968;
  background: #FFF0E8;
  padding: 6rpx 14rpx;
  border-radius: 10rpx;
  margin-left: 14rpx;
  white-space: nowrap;
  flex-shrink: 0;
}
.card-meta {
  display: flex;
  gap: 22rpx;
  margin-bottom: 18rpx;
  flex-wrap: wrap;
}
.meta-item {
  font-size: 24rpx;
  color: #8A7968;
}
.card-reason {
  background: #FFF8F3;
  padding: 18rpx 22rpx;
  border-radius: 14rpx;
  font-size: 26rpx;
  color: #2B2118;
  line-height: 1.55;
  margin-bottom: 22rpx;
  border-left: 6rpx solid #FF6B35;
  /* 长描述处理：按词换行，CJK 按字符，避免在标点中间生硬断行 */
  word-break: break-word;
  overflow-wrap: break-word;
}
.card-actions {
  display: flex;
  gap: 14rpx;
}
.action-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 14rpx;
  font-size: 26rpx;
  font-weight: 600;
  background: #FFF8F3;
  color: #FF6B35;
}
.action-btn.primary {
  background: #FF6B35;
  color: #FFFFFF;
}
.action-btn.ghost {
  background: transparent;
  color: #8A7968;
  border: 2rpx solid #EADFD6;
  flex: 0 0 auto;
  padding: 16rpx 22rpx;
}

/* 语义色：用于场景、状态、推荐标签 */
.tone-fresh {
  background: #3FA66B !important;
  color: #FFFFFF !important;
}

.tone-value {
  background: #F2A93B !important;
  color: #2B2118 !important;
}

.tone-warm {
  background: #FF8A5B !important;
  color: #FFFFFF !important;
}

.tone-spicy {
  background: #E94B35 !important;
  color: #FFFFFF !important;
}

.tone-late {
  background: #5B4034 !important;
  color: #FFFFFF !important;
}

/* === 悬浮红包按钮（CPS 入口，index 与 mystery 共享） === */
.float-coupon {
  position: fixed;
  right: 40rpx;
  bottom: calc(160rpx + env(safe-area-inset-bottom));
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B35, #FF9F1C);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.4);
  z-index: 100;
  animation: couponPulse 2.4s ease-in-out infinite;
}
.float-coupon-icon {
  font-size: 48rpx;
  line-height: 1;
}
.float-coupon-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  border-radius: 16rpx;
  background: #E63946;
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #FFFFFF;
  animation: none;
}
@keyframes couponPulse {
  0%, 100% { transform: scale(1); box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.4); }
  50% { transform: scale(1.08); box-shadow: 0 12rpx 32rpx rgba(255, 107, 53, 0.55); }
}

/* === 红包选择弹窗（底部 action-sheet，index 与 mystery 共享） === */
.coupon-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  z-index: 200;
  pointer-events: none;
  transition: background 0.25s ease;
}
.coupon-mask-show {
  background: rgba(0, 0, 0, 0.45);
  pointer-events: auto;
}
.coupon-picker {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFF8F3;
  border-radius: 28rpx 28rpx 0 0;
  padding: 12rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.28s ease;
}
.coupon-picker-show {
  transform: translateY(0);
}
.coupon-picker-title {
  text-align: center;
  font-size: 26rpx;
  color: #8A7968;
  padding: 18rpx 0 22rpx;
  font-weight: 600;
}
.coupon-picker-item {
  background: linear-gradient(135deg, #FF6B35, #FF9F1C);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  padding: 26rpx 0;
  border-radius: 40rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 4rpx 14rpx rgba(255, 107, 53, 0.25);
}
.coupon-picker-cancel {
  text-align: center;
  font-size: 28rpx;
  color: #8A7968;
  padding: 20rpx 0 8rpx;
}
