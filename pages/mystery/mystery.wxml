<view class="page mystery-page">
  <!-- 位置栏（共享样式，数据来自 globalData） -->
  <view class="loc-bar">
    <view class="loc-text" wx:if="{{locationOk}}">
      <text class="loc-icon">📍</text>
      <text class="loc-coord">{{address}}</text>
    </view>
    <view class="loc-text loc-warn" wx:else>
      <text class="loc-icon">📍</text>
      <text>{{locationError || '点击右侧授权定位'}}</text>
    </view>
    <view class="loc-action" bindtap="refreshLocation">
      {{locationOk ? '刷新' : '授权'}}
    </view>
  </view>

  <scroll-view scroll-y class="mystery-scroll">
    <view class="mystery-container">
      <!-- 未授权位置：定位中 / 引导用户授权 -->
      <view class="mystery-empty" wx:if="{{!locationOk}}">
        <text class="empty-icon">{{locating ? '📡' : '🥠'}}</text>
        <text class="empty-title">{{locating ? '定位中…' : '试试你的手气'}}</text>
        <text class="empty-desc" wx:if="{{!locating}}">点击右上角「授权」定位后，\n抽一家附近餐厅，看今天手气如何</text>
      </view>

      <!-- 盲盒主体（已授权） -->
      <block wx:else>
        <view class="mystery-box mystery-{{mysteryBox.status}}">
          <!-- 池耗尽状态 -->
          <view class="box-idle-wrap" wx:if="{{mysteryBox.poolExhausted}}">
            <view class="box-icon box-exhausted">🎯</view>
            <text class="box-hint">附近的好签都被抽完了</text>
            <text class="box-sub-hint">在上方点击「刷新」换个位置，解锁更多签</text>
          </view>

          <!-- 待机状态：毛玻璃幸运签 -->
          <view class="box-idle-wrap" wx:elif="{{mysteryBox.status === 'idle'}}">
            <view class="box-icon">🥠</view>
            <text class="box-hint">点下方按钮，试试今天的手气</text>
          </view>

          <!-- 开签动画 -->
          <view class="box-opening-wrap" wx:elif="{{mysteryBox.status === 'opening'}}">
            <view class="box-icon box-shaking">🥠</view>
            <text class="box-hint">摇签中…✨</text>
          </view>

          <!-- 揭晓结果 -->
          <view class="box-revealed-wrap" wx:else>
            <view class="reveal-badge">🎉 看看你抽到了啥</view>
            <restaurant-card
              card="{{mysteryBox.currentResult}}"
              variant="mystery"
              isMismatch="{{mysteryBox.currentResult.isMismatch}}"
              bind:navigate="onMysteryNav"
            />
          </view>
        </view>

        <!-- 开盲盒 / 再开一次按钮 -->
        <view class="mystery-action-bar">
          <button
            class="btn-mystery"
            bindtap="onOpenMysteryBox"
            disabled="{{mysteryBox.status === 'opening' || mysteryBox.poolExhausted}}"
            loading="{{mysteryBox.status === 'opening'}}"
          >
            {{mysteryBox.poolExhausted ? '🎯 已抽完' : (mysteryBox.status === 'opening' ? '摇签中…' : (mysteryBox.status === 'revealed' ? '🍀 再试一次手气' : '✨ 试试手气'))}}
          </button>
        </view>

        <!-- 历史记录（纵向列表，按开盒时间倒序） -->
        <view class="history-section" wx:if="{{mysteryBox.history.length > 0}}">
          <view class="history-header">
            <text class="history-title">本次抽过的签</text>
            <text class="history-count">共 {{mysteryBox.history.length}} 个</text>
          </view>
          <view class="history-list">
            <view
              wx:for="{{mysteryBox.history}}"
              wx:key="rank"
              class="history-card {{index === 0 ? 'history-card-latest' : ''}} {{mysteryBox.status === 'revealed' && mysteryBox.currentRank === item.rank ? 'history-card-active' : ''}}"
              data-idx="{{index}}"
              bindtap="onReopenHistory"
            >
              <view class="history-rank">第{{item.rank}}签</view>
              <view class="history-info">
                <view class="history-name-row">
                  <text class="history-name">{{item.name}}</text>
                  <text class="history-type" wx:if="{{item.card.type}}">{{item.card.type}}</text>
                </view>
                <view class="history-meta">
                  <text class="history-meta-item">📍 {{item.card.distanceText}}</text>
                  <text class="history-meta-item">⭐ {{item.card.ratingText}}</text>
                  <text class="history-meta-item" wx:if="{{item.card.costText}}">{{item.card.costText}}</text>
                </view>
              </view>
              <!-- 右侧并非「进入」入口，而是提示点击后该店铺会在上方展示，故用上箭头 -->
              <view class="history-arrow">↑</view>
            </view>
          </view>
          <view class="history-tip">点击任意一条，可在上方重新展示该店铺</view>
        </view>
      </block>
    </view>
  </scroll-view>

  <!-- 悬浮红包入口（平台级 CPS，配置齐全时展示）+ 选择弹窗 -->
  <coupon-float
    platforms="{{platformButtons}}"
    show="{{showCouponPicker}}"
    bind:toggle="onToggleCouponPicker"
    bind:open="onOpenPlatform"
  />
</view>
