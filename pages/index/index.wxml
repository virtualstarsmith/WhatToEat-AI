<view class="page">
  <!-- 位置栏（固定在顶部，不随内容滚动） -->
  <view class="loc-bar">
    <view class="loc-text" wx:if="{{locationOk}}">
      <text class="loc-icon">📍</text>
      <text class="loc-coord">{{address}}</text>
    </view>
    <view class="loc-text loc-warn" wx:else>
      <text class="loc-icon">📍</text>
      <text>{{locationError || '点击右侧授权定位'}}</text>
    </view>
    <view class="loc-action" bindtap="refreshLocation">
      {{locationOk ? '刷新' : '授权'}}
    </view>
  </view>

  <!-- 内容滚动区 -->
  <scroll-view scroll-y class="content-scroll">
    <!-- 场景栏 -->
    <view class="scene-section">
      <scroll-view scroll-x="{{true}}" class="scene-scroll" enhanced="{{true}}" show-scrollbar="{{false}}">
        <view class="scene-list">
          <view
            wx:for="{{sceneOptions}}"
            wx:key="name"
            class="scene-chip {{scene === item.name ? 'scene-chip-active' : ''}} {{scene === item.name ? item.tone : ''}} {{(loading || refreshing) && scene !== item.name ? 'scene-chip-disabled' : ''}}"
            data-scene="{{item.name}}"
            bindtap="onSelectScene"
          >
            {{item.label}}
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 快捷筛选栏：下拉面板式（见 06-26-ai-pick-filter-bar）。
         3个维度标签按钮，点击展开下拉选项；默认不选=不限。 -->
    <view class="filter-bar" wx:if="{{locationOk}}">
      <view
        class="filter-tab {{filters[group.key] ? 'filter-tab-active' : ''}} {{activeFilter === group.key ? 'filter-tab-open' : ''}} {{(loading || refreshing) ? 'filter-tab-disabled' : ''}}"
        wx:for="{{filterGroups}}"
        wx:for-item="group"
        wx:key="key"
        data-key="{{group.key}}"
        bindtap="onToggleFilter"
      >
        <!-- 已选显示值，未选显示维度名 -->
        <text class="filter-tab-label">{{filters[group.key] ? group.selectedLabel[filters[group.key]] : group.label}}</text>
        <text class="filter-tab-arrow">{{activeFilter === group.key ? '▲' : '▾'}}</text>
      </view>
    </view>

    <!-- 筛选下拉面板：点击维度标签后展开 -->
    <view class="filter-panel-mask" wx:if="{{activeFilter}}" bindtap="onCloseFilter"></view>
    <view class="filter-panel" wx:if="{{activeFilter}}">
      <view class="filter-panel-title">{{activeFilterLabel}}</view>
      <view class="filter-panel-options">
        <view
          class="filter-option {{filters[activeFilter] === opt.value ? 'filter-option-active' : ''}}"
          wx:for="{{activeFilterOptions}}"
          wx:for-item="opt"
          wx:key="value"
          data-key="{{activeFilter}}"
          data-value="{{opt.value}}"
          bindtap="onPickFilter"
        >{{opt.label}}</view>
      </view>
    </view>

    <!-- 兜底提示：不暴露"失败"，用中性语气承接，避免戳破推荐的连续感 -->
    <view class="banner-fallback" wx:if="{{source === 'fallback' && cardsView.length > 0}}">
      💬 为你又挑了几家，看看哪家合口味
    </view>

    <!-- 刷新提示（有旧推荐时，保留旧推荐 + 顶部小加载条） -->
    <view class="refresh-banner" wx:if="{{loading && cardsView.length > 0}}">
      <text class="refresh-banner-text">正在刷新推荐…</text>
    </view>

    <!-- 首次加载提示（无旧推荐时） -->
    <view class="hint" wx:if="{{loading && cardsView.length === 0}}">
      <text>正在为你寻找附近的店…</text>
    </view>

    <!-- Error -->
    <view class="hint hint-error" wx:if="{{error && !loading}}">
      <text>{{error}}</text>
      <view class="btn-retry" bindtap="onRefresh">重试</view>
    </view>

    <!-- 推荐卡片（loading 时也保留显示，避免刷新时推荐消失） -->
    <view class="cards" wx:if="{{cardsView.length > 0}}">
      <restaurant-card
        wx:for="{{cardsView}}"
        wx:key="poi_id"
        card="{{item}}"
        variant="index"
        bind:navigate="onOpenNav"
        bind:coupon="onOpenCommercial"
      />
    </view>

    <!-- 换一批 -->
    <view class="refresh-bar" wx:if="{{cardsView.length > 0}}">
      <button class="btn-refresh" bindtap="onRefresh" loading="{{refreshing}}">
        {{refreshing ? '换一批中…' : '换一批'}}
      </button>
    </view>
  </scroll-view>

  <!-- 悬浮红包入口（平台级 CPS，配置齐全时展示）+ 选择弹窗 -->
  <coupon-float
    platforms="{{platformButtons}}"
    show="{{showCouponPicker}}"
    bind:toggle="onToggleCouponPicker"
    bind:open="onOpenPlatform"
  />
</view>
