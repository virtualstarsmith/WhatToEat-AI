/* 首页 AI 推荐专属样式（公共样式 loc-bar / card / action-btn 见 app.wxss） */

/* 内容滚动区：固定高度，让 scroll-view 真正接管滚动，
   位置栏 loc-bar 在 scroll-view 外面 → 始终固定在顶部。
   高度扣除：loc-bar 约 100rpx + 页面 padding-top 24rpx + 底部 tabBar 100rpx + 安全区 */
.content-scroll {
  height: calc(100vh - 224rpx - env(safe-area-inset-bottom));
}

/* === 场景栏 === */
.scene-section {
  margin-bottom: 28rpx;
}
.scene-scroll {
  width: 100%;
  white-space: nowrap;
}
.scene-list {
  display: inline-flex;
  gap: 16rpx;
  padding: 6rpx 0 12rpx;
}
.scene-chip {
  display: inline-block;
  padding: 14rpx 30rpx;
  border-radius: 36rpx;
  background: #FFFFFF;
  font-size: 26rpx;
  color: #2B2118;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
  flex-shrink: 0;
}
.scene-chip-active {
  background: #FF6B35;
  color: #FFFFFF;
  font-weight: 600;
  box-shadow: 0 4rpx 14rpx rgba(255, 107, 53, 0.22);
}
/* 加载中：非当前场景 chip 降透明度，提示暂不可切换（点击由 onSelectScene 守卫拦截） */
.scene-chip-disabled {
  opacity: 0.5;
}

/* === Banner === */
.banner-fallback {
  background: rgba(255, 107, 53, 0.1);
  color: #C04E22;
  padding: 16rpx 22rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  margin-bottom: 22rpx;
  line-height: 1.5;
}

/* === 刷新提示条（有旧推荐时，顶部小加载提示） === */
.refresh-banner {
  background: rgba(255, 107, 53, 0.08);
  border-radius: 12rpx;
  padding: 14rpx 22rpx;
  margin-bottom: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.refresh-banner-text {
  font-size: 24rpx;
  color: #FF6B35;
  font-weight: 600;
}
.refresh-banner-text::before {
  content: '⟳ ';
  display: inline-block;
  animation: refreshSpin 1s linear infinite;
}
@keyframes refreshSpin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* === Hint === */
.hint {
  padding: 80rpx 24rpx;
  text-align: center;
  color: #8A7968;
  font-size: 28rpx;
}
.hint-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}
.btn-retry {
  background: #FF6B35;
  color: #FFFFFF;
  font-size: 26rpx;
  padding: 14rpx 40rpx;
  border-radius: 30rpx;
  font-weight: 600;
}

/* === 卡片列表 === */
.cards {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* === 换一批 === */
.refresh-bar {
  margin-top: 40rpx;
  /* 底部 60rpx 留白：避免被底部 tabBar（100rpx + 安全区）遮住，
     与盲盒页 .mystery-container 的 padding-bottom: 60rpx 保持一致 */
  padding: 0 40rpx 60rpx;
}
.btn-refresh {
  background: #5B4034;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 50rpx;
  padding: 22rpx 0;
}
.btn-refresh::after {
  border: 0;
}
